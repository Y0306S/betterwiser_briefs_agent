__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Git history (not needed in image)
.git/

# Docs and dev files
*.md
*.docx
*.pdf
SETUP*
