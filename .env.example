# BetterWiser Legal-Tech AI Briefing Agent — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Required: Anthropic API key (minimum needed to run dry-run)
ANTHROPIC_API_KEY=

# Required for inbox reading and email sending (Azure AD app registration)
# See SETUP.md for step-by-step Azure AD setup instructions
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_USER_EMAIL=ai-briefing@betterwiser.com

# Optional: Spider API key for Tier 2 web scraping (pay-as-you-go)
# Without this, scraping falls back to Jina Reader (free) + Crawl4AI
SPIDER_API_KEY=

# Optional: Tavily API key for deep thought leadership research (Wave 4)
# Without this, Wave 4 is skipped; Claude web search covers Waves 1-3, 5-6
TAVILY_API_KEY=
